{
  "name": "lumies-job",
  "version": "1.0.0",
  "description": "",
  "main": "",
  "scripts": {
    "minify:js": "for %f in (src\\*.js) do (terser \"%f\" -o \"dist/%~nf.js\" -c -m)",
    "minify:css": "for %f in (src\\gift\\*.css) do (postcss -o \"dist/gift/%~nf.css\" \"%f\")",
    "prog:js": "for %f in (src\\pay.js) do (terser \"%f\" -o \"dist//%~nf.js\" -c -m)",
    "prog:css": "for %f in (src\\pay.css) do (postcss -o \"dist//%~nf.css\" \"%f\")",
    "prog:html": "for %f in (src\\payment.html) do (html-minifier-terser --collapse-whitespace --remove-comments \"%f\" -o \"dist//%~nf.html\")",
    "p1:html": "for %f in (src\\gift\\*.html) do (html-minifier-terser --collapse-whitespace --remove-comments \"%f\" -o \"dist/gift/%~nf.html\")",
    "p2:html": "for %f in (src\\impact\\*.html) do (html-minifier-terser --collapse-whitespace --remove-comments \"%f\" -o \"dist/impact/%~nf.html\")",
    "p3:html": "for %f in (src\\problems\\*.html) do (html-minifier-terser --collapse-whitespace --remove-comments \"%f\" -o \"dist/problems/%~nf.html\")",
    "p4:html": "for %f in (src\\serve\\*.html) do (html-minifier-terser --collapse-whitespace --remove-comments \"%f\" -o \"dist/serve/%~nf.html\")",
    "minify:html": "for %f in (src\\*.html) do (html-minifier-terser --collapse-whitespace --remove-comments \"%f\" -o \"dist/%~nf.html\")",
    "build": "npm run minify:css & npm run minify:html & npm run minify:js",
    "build_ii": "npm run prog:css & npm run prog:html & npm run prog:js",
    "build_iii": "npm run minify:html & npm run p1:html & npm run p2:html & npm run p3:html & npm run p4:html",
    "build_iv": "npm run prog:css & npm run minify:css"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "cssnano": "^8.0.2",
    "html-minifier-terser": "^7.2.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "terser": "^5.48.0"
  }
}
